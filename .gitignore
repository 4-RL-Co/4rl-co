# build & deps
node_modules/
dist/
.astro/
.vercel/
.output/

# aeo.js output. Generated on every build, so tracking it only ever produced
# a dirty diff. Worse, the local build writes a gutted stub over public/ (a
# 935-byte llms-full.txt against the real 8184) while writing the correct file
# to dist/, which is what actually deploys. So the committed copies were both
# stale and wrong, and reviewing a real change meant picking them out by hand.
# Verified: with these absent, a clean build still emits all seven to dist/.
public/llms.txt
public/llms-full.txt
public/ai-index.json
public/schema.json
public/docs.json
public/sitemap.xml
public/robots.txt

# env: ignore every env file, but keep the documented template
.env
.env.*
!.env.example

# secrets / keys (never commit these)
*.pem
*.key
*.p12
*.pfx
id_rsa*
*.keystore
secrets.json
.secrets/

# os / editor / logs
.DS_Store
Thumbs.db
npm-debug.log*
yarn-error.log*
*.local

# personal notes
Como usar o mark (Claude Code).md

# Source artwork kept locally, not versioned. These are the untrimmed, full-size
# masters the site's assets were derived from: gumehome.png became
# src/assets/gume-home.png, and the other three became public/ventures/*. What
# the site actually serves is committed; these are only here to re-cut from, so
# they stay out of the repo rather than adding ~5MB of pixels nothing builds on.
/gumehome.png
/d.lablogo.png
/m1m1cbox.png
/labepi-vetores-12.svg
