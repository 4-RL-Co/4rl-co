# ---------------------------------------------------------------------------
# Environment template. Copy to `.env` (which is git-ignored) and fill values.
#   cp .env.example .env
# NEVER put real values in THIS file — it is committed. Real values live only
# in `.env` (local) and in the deploy provider's env settings (Vercel, etc.).
# ---------------------------------------------------------------------------

# Cloudflare Web Analytics beacon site-tag.
# This is a PUBLIC value (it ships in the page), not a secret/API key — but we
# still keep it out of source so it can be rotated without touching code.
# The analytics beacon only loads when this is set; the site works fine without it.
# Get it: Cloudflare dashboard -> Web Analytics -> your site -> the token in the snippet.
PUBLIC_CF_BEACON_TOKEN=

# Microsoft Clarity project id (the string in clarity.ms/tag/<id>).
# Also PUBLIC (ships in the page); kept in env so it isn't hardcoded and can change freely.
# The Clarity script only loads when this is set.
# Get it: Clarity dashboard -> Settings -> Overview (or the install snippet).
PUBLIC_CLARITY_ID=
