---
import { news, outlets } from '../data/news.js';
---
<section class="news" id="news">
  <div class="wrap">
    <p class="seclabel reveal"><span class="n">03</span> <span class="slash">/</span> News · Press</p>

    <ul class="news__list">
      {news.map((item) => (
        <li class={'reveal' + (item.flagship ? ' is-flag' : '')}>
          <a class="news__row row" href={item.href} target="_blank" rel="noopener">
            <span class="news__year mono">{item.year}</span>
            <span class="news__outlet mono">{item.outlet}</span>
            <span class="news__title">
              {item.flagship && <span class="news__flag mono">Flagship</span>}
              {item.title}
            </span>
            <span class="arr news__arr" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- "as seen in" : scrolling marquee of outlet names -->
    <div class="news__seen reveal">
      <span class="mono news__seen-label">As seen in</span>
      <div class="marquee news__marquee" aria-hidden="true">
        <div class="marquee__track">
          {[...outlets, ...outlets, ...outlets].map((o) => (
            <span class="news__seen-item">{o}<span class="slash"> / </span></span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .news{ padding-top:clamp(64px,9vh,110px); padding-bottom:clamp(56px,8vh,100px); }
  .news__list{ list-style:none; }
  .news__row{
    display:grid; grid-template-columns:70px 1fr 3fr auto;
    align-items:baseline; gap:clamp(14px,2.4vw,40px);
    padding:clamp(16px,2.2vw,26px) 0; border-top:1px solid var(--line);
    transition:padding-left .35s var(--ease);
  }
  .news__list li:last-child .news__row{ border-bottom:1px solid var(--line); }
  .news__row:hover{ padding-left:14px; }
  .news__year{ color:var(--ink-muted); }
  .news__outlet{ color:var(--ink); letter-spacing:.1em; }
  .news__title{
    font-family:var(--font-display); font-weight:600; letter-spacing:-.02em;
    font-size:clamp(17px,2.1vw,30px); line-height:1.08; color:var(--ink);
    transition:color .3s var(--ease);
  }
  .news__row:hover .news__title{ color:var(--accent); }
  .news__flag{
    display:inline-block; vertical-align:middle; margin-right:10px;
    color:#0A0A0B; background:var(--accent); padding:3px 8px; border-radius:100px; font-size:10px;
  }
  .news__arr{ color:var(--accent); font-size:20px; align-self:center; }
  .is-flag .news__row{ background:linear-gradient(90deg, rgba(198,255,58,.05), transparent 55%); }

  .news__seen{ margin-top:clamp(40px,6vh,72px); }
  .news__seen-label{ display:block; margin-bottom:16px; }
  .news__marquee{ border-top:1px solid var(--line); border-bottom:1px solid var(--line); padding:14px 0; }
  .news__seen-item{
    font-family:var(--font-display); font-weight:700; letter-spacing:-.02em;
    font-size:clamp(18px,2.6vw,38px); color:var(--ink-muted); padding:0 4px;
  }

  @media (max-width:820px){
    .news__row{ grid-template-columns:52px 1fr auto; }
    .news__outlet{ display:none; }
  }
</style>
