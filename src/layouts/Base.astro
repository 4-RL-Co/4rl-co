---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const {
  title = '4/RL Co. · Independent AI Venture Studio',
  description = 'We improve the world with AI. For real. An independent AI venture studio building and operating ventures across influence, science, applied AI and cinema.',
  twitterDesc = 'We improve the world with AI. For real.',
  jsonLd,
} = Astro.props;
// SITE_URL — the canonical 4/RL domain (used for absolute OG/Twitter image URLs).
const site = 'https://www.4real.ventures';
// Public Cloudflare Web Analytics beacon token (kept in an env var, not in source).
const cfToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
// Microsoft Clarity project id (public tag; kept in an env var, not in source).
const clarityId = import.meta.env.PUBLIC_CLARITY_ID;

const isHome = Astro.url.pathname === '/';
// Per-page canonical / OG url (was hardcoded to the homepage on every page).
const canonicalURL = site + Astro.url.pathname;
// Brand social profiles — used for schema.org sameAs (entity linking).
const social = [
  'https://www.linkedin.com/company/4rl-co/',
  'https://github.com/olegas4real',
  'https://t.me/olegas4real',
];
// Homepage structured data — Organization, WebSite and WebPage emitted as
// separate top-level JSON-LD blocks (not wrapped in @graph). Cross-links via
// @id still resolve across blocks, and a top-level Organization node is what
// crawlers/audits look for when reading the company name + logo.
const orgNode = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site}/#organization`,
  name: '4/RL Co.',
  alternateName: '4RL',
  url: site,
  logo: `${site}/favicon-512.png`,
  image: `${site}/og-image.png`,
  description,
  foundingLocation: { '@type': 'Place', name: 'São Paulo, BR' },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'olegas@4real.ventures',
    telephone: '+5511933279420',
    areaServed: 'BR',
    availableLanguage: ['Portuguese', 'English'],
  },
  founder: { '@type': 'Person', name: 'Gabriel Olegário', sameAs: social },
  sameAs: social,
  subOrganization: [
    { '@type': 'Organization', name: 'Smart Social', url: 'https://smtsocial.com.br/' },
    { '@type': 'Organization', name: 'LabEpi', url: 'https://laboratoriodeepidemiologia.com/' },
    { '@type': 'Organization', name: 'D.Lab Experts', url: 'https://dlabexperts.com/' },
    { '@type': 'Organization', name: 'M1m1c Box', url: 'https://www.youtube.com/@m1m1cbox' },
  ],
};
const websiteNode = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${site}/#website`,
  url: site,
  name: '4/RL Co.',
  description,
  publisher: { '@id': `${site}/#organization` },
  inLanguage: 'en',
};
const webpageNode = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonicalURL}#webpage`,
  url: canonicalURL,
  name: title,
  description,
  isPartOf: { '@id': `${site}/#website` },
  about: { '@id': `${site}/#organization` },
  primaryImageOfPage: `${site}/og-image.png`,
  inLanguage: 'en',
};
const homeSchemas = [orgNode, websiteNode, webpageNode];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  {/* CSP fallback for hosts that can't set headers (e.g. GitHub Pages). Prod only,
     so it doesn't interfere with the dev server's HMR websocket. On Vercel/Netlify
     the header version in vercel.json / _headers also applies. */}
  {import.meta.env.PROD && (
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self' data: https://*.clarity.ms; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://www.clarity.ms https://*.clarity.ms; connect-src 'self' https://cloudflareinsights.com https://static.cloudflareinsights.com https://*.clarity.ms https://c.bing.com; manifest-src 'self'; form-action 'self'; upgrade-insecure-requests"
    />
  )}
  {/* Microsoft Clarity — loads early; project id comes from env, never hardcoded. */}
  {clarityId && (
    <script is:inline set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${clarityId}");`} />
  )}
  <!-- before-paint flags: reveal animation opt-in + preloader once-per-session -->
  <script is:inline>
    (function () {
      var h = document.documentElement;
      try { if (!matchMedia('(prefers-reduced-motion: reduce)').matches) h.classList.add('js'); } catch (e) {}
      try { if (sessionStorage.getItem('4rl_pre')) h.classList.add('preloaded'); } catch (e) {}
    })();
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0A0A0B" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
  <link rel="dns-prefetch" href="https://www.clarity.ms" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/4rl-favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/favicon-180.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="4/RL Co." />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={site + '/og-image.png'} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={twitterDesc} />
  <meta name="twitter:image" content={site + '/og-image.png'} />

  {/* structured data: Organization on the homepage, page-specific schema elsewhere */}
  {isHome && homeSchemas.map((node) => <script type="application/ld+json" set:html={JSON.stringify(node)} />)}
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
</head>
<body>
  <div class="preloader" id="preloader" aria-hidden="true">
    <img src="/4rl-mark.svg" alt="4/RL Co. logo" width="60" height="60" />
  </div>

  <div class="cursor" id="cursor" aria-hidden="true"></div>
  <div class="cursor-dot" id="cursorDot" aria-hidden="true"></div>

  <slot />

  {cfToken && (
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfToken}"}`}></script>
  )}

  {/* Vercel first-party analytics (pageviews) — served from /_vercel/insights/* */}
  <Analytics />

  <script>
    /* ---- Scroll reveals: never leave content hidden ---- */
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = Array.from(document.querySelectorAll('.reveal'));
    const showAll = () => items.forEach((el) => el.classList.add('in'));
    if (reduce || !('IntersectionObserver' in window)) {
      showAll();
    } else {
      const vh = () => window.innerHeight || document.documentElement.clientHeight;
      // reveal anything already in view immediately (fast, no wait)
      items.forEach((el) => { const r = el.getBoundingClientRect(); if (r.top < vh() * 0.92) el.classList.add('in'); });
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0, rootMargin: '0px 0px -6% 0px' });
      items.forEach((el) => { if (!el.classList.contains('in')) io.observe(el); });
      // safety net: nothing stays hidden longer than 1.2s
      setTimeout(showAll, 1200);
    }

    /* ---- Preloader: mark hold, then a "/" wipe. Once per session. Non-blocking. ---- */
    const pre = document.getElementById('preloader');
    if (pre) {
      if (document.documentElement.classList.contains('preloaded')) {
        pre.remove();                              // already shown this session
      } else {
        try { sessionStorage.setItem('4rl_pre', '1'); } catch (e) {}
        const gone = () => pre.remove();
        if (reduce) { pre.classList.add('fade'); setTimeout(gone, 160); }
        else { setTimeout(() => { pre.classList.add('wipe'); setTimeout(gone, 480); }, 240); }
      }
    }

    /* ---- Custom cursor (desktop pointer only) ---- */
    const fine = window.matchMedia('(hover:hover) and (pointer:fine)').matches;
    if (fine && !reduce) {
      document.documentElement.classList.add('hide-cursor'); /* hide OS cursor */
      const c = document.getElementById('cursor');
      const d = document.getElementById('cursorDot');
      let cx = innerWidth / 2, cy = innerHeight / 2, dx = cx, dy = cy;
      addEventListener('pointermove', (e) => {
        cx = e.clientX; cy = e.clientY;
        d.style.transform = `translate(${cx}px,${cy}px) translate(-50%,-50%)`;
        c.style.opacity = '1'; d.style.opacity = '1';
      }, { passive: true });
      (function loop() {
        dx += (cx - dx) * 0.18; dy += (cy - dy) * 0.18;
        c.style.transform = `translate(${dx}px,${dy}px) translate(-50%,-50%)`;
        requestAnimationFrame(loop);
      })();
      const hover = (on) => () => c.classList.toggle('is-hover', on);
      document.querySelectorAll('a,button,[data-cursor]').forEach((el) => {
        el.addEventListener('pointerenter', hover(true));
        el.addEventListener('pointerleave', hover(false));
      });
    }
  </script>
</body>
</html>
